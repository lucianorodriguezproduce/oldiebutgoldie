rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core Functions
    function isAdmin() {
      return request.auth != null && (
        request.auth.uid == "MKPlxxi9JENQt0hS3V1QNeF8oOS2" ||
        request.auth.token.email == "admin@discography.ai" ||
        request.auth.token.email == "lucianorodriguez.produce@gmail.com"
      );
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Branding & Config - Solo Admin
    match /settings/{document=**} {
      allow read, write: if isAdmin();
    }

    // Telemetry - Creación libre, gestión Admin
    match /interactions/{document=**} {
      allow create: if true;
      allow read, delete: if isAdmin();
    }
    
    // User data - Lectura para perfiles (usernames), escritura solo dueño o Admin
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if isOwner(userId) || isAdmin();
    }

    // Usernames Registry - Lectura pública para búsquedas
    match /usernames/{username} {
      allow read: if true;
      allow write: if request.auth != null && (
        !exists(/databases/$(database)/documents/usernames/$(username)) || 
        get(/databases/$(database)/documents/usernames/$(username)).data.uid == request.auth.uid
      ) || isAdmin();
    }

    // Connections - Soberanía compartida entre las partes
    match /connections/{connectionId} {
      allow read: if request.auth != null && (
        isAdmin() ||
        !exists(/databases/$(database)/documents/connections/$(connectionId)) ||
        request.auth.uid == resource.data.requesterId || 
        request.auth.uid == resource.data.receiverId
      );
      allow create: if request.auth != null && 
        request.auth.uid == request.resource.data.requesterId;
      allow update, delete: if request.auth != null && (
        request.auth.uid == resource.data.requesterId || 
        request.auth.uid == resource.data.receiverId ||
        isAdmin()
      );
    }

    // Editorial - Lectura pública, gestión Admin
    match /editorial/{document=**} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Subscribers - Suscripción libre, gestión Admin
    match /subscribers/{document=**} {
      allow create: if true;
      allow read, delete: if isAdmin();
    }

    // Leads - Solo Admin
    match /leads/{document=**} {
      allow read, write: if isAdmin();
    }

    // Orders - Pedidos públicos, gestión Admin
    match /orders/{document=**} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // Notifications - Solo dueño o Admin
    match /notifications/{document=**} {
      allow read, write, delete: if request.auth != null && (
        resource == null || resource.data.uid == request.auth.uid || isAdmin()
      );
    }

    // Inventory - El Búnker: Lectura pública. 
    // Los usuarios pueden CREAR si el estado es 'archived' (viaje al archivo).
    match /inventory/{itemId} {
      allow read: if true;
      allow create: if request.auth != null && (isAdmin() || request.resource.data.logistics.status == "archived");
      allow update: if request.auth != null && (isAdmin() || request.resource.data.logistics.status == "archived");
      allow delete: if isAdmin();

      // Regla recursiva para campos anidados si se requiere
      match /{allPaths=**} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // Trades - Negociaciones: Solo participantes o Admin
    match /trades/{tradeId} {
      allow read: if request.auth != null && (
        isAdmin() ||
        request.auth.uid == resource.data.participants.senderId ||
        request.auth.uid == resource.data.participants.receiverId ||
        request.auth.uid == resource.data.highest_bidder_uid
      );
      allow write: if request.auth != null;
      allow delete: if isAdmin();

      // Messaging Engine (Protocol V24.5)
      match /messages/{messageId} {
        allow read: if request.auth != null && (
          isAdmin() ||
          request.auth.uid == get(/databases/$(database)/documents/trades/$(tradeId)).data.participants.senderId ||
          request.auth.uid == get(/databases/$(database)/documents/trades/$(tradeId)).data.highest_bidder_uid
        );
        allow create: if request.auth != null && (
          request.auth.uid == get(/databases/$(database)/documents/trades/$(tradeId)).data.participants.senderId ||
          request.auth.uid == get(/databases/$(database)/documents/trades/$(tradeId)).data.highest_bidder_uid
        );
      }
    }

    // User Assets - Soberanía y Blindaje: Solo dueño o Admin
    // Armonizado para usar 'ownerId' o 'uid' (Protocolo V21.7)
    match /user_assets/{assetId} {
      allow read: if resource == null || resource.data.status == "active" || (request.auth != null && (isAdmin() || resource.data.ownerId == request.auth.uid || resource.data.uid == request.auth.uid));
      allow create: if request.auth != null && (request.resource.data.ownerId == request.auth.uid || request.resource.data.uid == request.auth.uid || isAdmin());
      allow update, delete: if request.auth != null && (resource.data.ownerId == request.auth.uid || resource.data.uid == request.auth.uid || isAdmin());
    }

    // Lotes y Carritos - Gestión Admin
    match /lotes/{document=**} {
      allow read, write: if isAdmin();
    }

    // Purchase Requests - Abierto para creación de usuario
    match /purchase_requests/{requestId} {
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /p2p_market/{document=**} {
      allow read, write: if isAdmin();
    }

    // Internal Categories - Lectura pública, gestión Admin
    match /internal_categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Articles & Editorial Assets - Lectura pública, gestión Admin
    match /articles/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Analytics Intents & Missed Searches - Gestión Admin
    match /analytics_intents/{document=**} {
      allow create: if true;
      allow read, delete: if isAdmin();
    }
    match /missed_searches/{document=**} {
      allow create: if true;
      allow read, delete: if isAdmin();
    }

    // System Cache & Config
    match /system_cache/{document=**} {
      allow read, write: if true; 
    }
    match /system_config/{document=**} {
      allow read: if true;
      allow write: if isAdmin(); 
    }
  }
}
